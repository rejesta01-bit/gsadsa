                if now - (Menu.PlayerList.lastRefresh or 0) >= (Menu.PlayerList.refreshInterval or 2000) then
                    Menu.PlayerList.lastRefresh = now
                    Menu.RefreshOnlinePlayers()
                end
            end
        end)
        Wait(1000)
    end
end)

